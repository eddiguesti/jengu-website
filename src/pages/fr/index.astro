---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { generateSEO } from '../../lib/seo/metadata';
import { generateOrganizationSchema, generateWebSiteSchema } from '../../lib/seo/jsonld';

const seo = generateSEO({
  title: 'Automatisation IA pour le tourisme et l\'hôtellerie',
  description: 'Transformez votre entreprise touristique avec des agents IA sur mesure. Automatisez vos réservations, votre support client et vos opérations. Jusqu\'à 30 % de conversions en plus, plus de 40 heures gagnées par semaine. Calculateur de ROI et consultation gratuits.',
  canonical: `${Astro.site?.href}fr/`,
  ogType: 'website'
});

const jsonLd = [
  generateOrganizationSchema(),
  generateWebSiteSchema()
];
---

<BaseLayout seo={seo} jsonLd={jsonLd}>
  <section class="hero hero-home">
    <div class="hero-container">
      <div class="hero-content">
        <span class="hero-badge hero-animate">
          <i class="fas fa-sparkles"></i>
          <span class="jengu-brand">JENGU</span> — Automatisation IA pour le Tourisme et l'Hôtellerie
        </span>

        <!-- Desktop headline -->
        <h1 class="desktop-only hero-animate" data-delay="1">
          Des agents IA intelligents pour l'hôtellerie. <span class="gradient-text">Plus d'efficacité, plus de revenus.</span>
        </h1>

        <!-- Mobile headline - animated -->
        <h1 class="mobile-only mobile-hero-title">
          L'IA qui pilote<br/>vos opérations
        </h1>

        <!-- Desktop description -->
        <p class="hero-description desktop-only hero-animate" data-delay="2">
          Une automatisation unifiée pour vos tâches, vos communications et l'expérience client.
        </p>

        <!-- Desktop CTAs -->
        <div class="hero-cta-group desktop-only hero-animate" data-delay="3">
          <button onclick="openBookingModal()" class="btn btn-primary btn-large btn-modern">
            <span>Consultation Gratuite</span>
          </button>
          <a href="/fr/calculator" class="btn btn-secondary btn-large btn-modern" id="calc-btn">
            <span>Calculez Votre ROI</span>
          </a>
        </div>
        <p class="hero-trust desktop-only hero-animate" data-delay="4">
          <i class="fas fa-check-circle"></i>
          ROI prouvé • Résultats concrets • Pilote sans engagement
        </p>
      </div>


      <!-- Desktop only: Spline 3D Robot -->
      <div class="hero-visual desktop-only hero-animate" data-delay="5">
        <div class="spline-container" role="img" aria-label="Animation 3D de robot interactif">
          <spline-viewer
            url="https://prod.spline.design/H0BsfAOW2BCmCUyJ/scene.splinecode"
            loading="lazy"
          ></spline-viewer>
        </div>
      </div>

      <!-- Deferred Spline Viewer Loading - OPTIMIZED: Pause when not visible -->
      <script>
        function loadSplineViewer() {
          const script = document.createElement('script');
          script.type = 'module';
          script.src = 'https://unpkg.com/@splinetool/viewer@1.12.4/build/spline-viewer.js';
          document.head.appendChild(script);

          script.onload = () => {
            const container = document.querySelector('.spline-container');
            const viewer = document.querySelector('spline-viewer');
            if (!viewer || !container) return;

            let checkCount = 0;
            const maxChecks = 30;

            function checkCanvasReady() {
              const canvas = viewer.shadowRoot?.querySelector('canvas');
              if (canvas && canvas.width > 0) {
                container.classList.add('loaded');
                setupVisibilityOptimization(viewer);
              } else if (checkCount < maxChecks) {
                checkCount++;
                requestAnimationFrame(() => setTimeout(checkCanvasReady, 100));
              } else {
                container.classList.add('loaded');
                setupVisibilityOptimization(viewer);
              }
            }
            requestAnimationFrame(checkCanvasReady);
          };
        }

        function setupVisibilityOptimization(viewer) {
          if (!viewer) return;
          let splineApp = null;
          let isPaused = false;
          const getSplineApp = () => { try { return viewer._app || viewer.spline || null; } catch (e) { return null; } };

          const visibilityObserver = new IntersectionObserver((entries) => {
            const isVisible = entries[0].isIntersecting;
            if (!splineApp) splineApp = getSplineApp();
            if (isVisible && isPaused) {
              isPaused = false;
              if (splineApp && typeof splineApp.play === 'function') splineApp.play();
            } else if (!isVisible && !isPaused) {
              isPaused = true;
              if (splineApp && typeof splineApp.stop === 'function') splineApp.stop();
            }
          }, { threshold: 0.1 });
          visibilityObserver.observe(viewer);

          document.addEventListener('visibilitychange', () => {
            if (!splineApp) splineApp = getSplineApp();
            if (document.hidden && !isPaused) {
              isPaused = true;
              if (splineApp && typeof splineApp.stop === 'function') splineApp.stop();
            } else if (!document.hidden && isPaused) {
              const rect = viewer.getBoundingClientRect();
              if (rect.top < window.innerHeight && rect.bottom > 0) {
                isPaused = false;
                if (splineApp && typeof splineApp.play === 'function') splineApp.play();
              }
            }
          });
        }

        if ('requestIdleCallback' in window) {
          requestIdleCallback(loadSplineViewer, { timeout: 2000 });
        } else {
          setTimeout(loadSplineViewer, 1000);
        }
      </script>
    </div>

    <!-- Mobile & Tablet: Fullscreen Video Hero -->
    <div class="mobile-only video-bg">
      <video autoplay muted playsinline loop id="bg-video" preload="metadata" poster="/images/mobile-hero-poster.jpg">
        <source id="video-source" type="video/mp4">
      </video>
      <script is:inline>
        // Select video based on viewport width
        const bgVideo = document.getElementById('bg-video');
        const videoSource = document.getElementById('video-source');
        if (bgVideo && videoSource) {
          const isMobile = window.innerWidth < 768;
          videoSource.src = isMobile ? '/videos/mobile-hero.mp4' : '/videos/tablet-hero.mp4';
          bgVideo.load();

          // Start at 7 seconds only for mobile
          if (isMobile) {
            bgVideo.addEventListener('loadedmetadata', function() {
              bgVideo.currentTime = 7;
            });
          }
        }
      </script>

      <!-- Gradient overlay -->
      <div class="mobile-hero-gradient"></div>

      <!-- Content overlay -->
      <div class="mobile-hero-overlay">
        <!-- Tablet-only badge -->
        <span class="tablet-hero-badge">
          <i class="fas fa-sparkles"></i>
          <span class="jengu-brand">JENGU</span> — Automatisation IA pour le Tourisme et l'Hôtellerie
        </span>

        <!-- Mobile headline -->
        <h1 class="mobile-hero-headline mobile-headline-only">
          L'IA qui pilote<br/>vos opérations
        </h1>

        <!-- Tablet headline - matches desktop -->
        <h1 class="tablet-hero-headline">
          Des agents IA intelligents pour l'hôtellerie.<br/><span class="gradient-text">Plus d'efficacité, plus de revenus.</span>
        </h1>

        <!-- Mobile subhead -->
        <div class="mobile-subhead mobile-subhead-only">Pour l'hôtellerie. Plus de revenus, moins de saisie manuelle.</div>

        <!-- Tablet-only description - matches desktop -->
        <p class="tablet-hero-description">
          Une automatisation unifiée pour vos tâches, vos communications et l'expérience client.
        </p>

        <div class="mobile-hero-actions">
          <button onclick="openBookingModal()" class="mobile-hero-btn mobile-hero-btn-primary">
            <span class="mobile-btn-text">Consultation</span>
            <span class="tablet-btn-text">Consultation Gratuite</span>
          </button>
          <a href="/fr/calculator" class="mobile-hero-btn mobile-hero-btn-secondary">
            <span class="mobile-btn-text">Calculez ROI</span>
            <span class="tablet-btn-text">Calculez Votre ROI</span>
          </a>
        </div>

        <!-- Tablet-only trust indicators -->
        <div class="tablet-hero-trust">
          <div class="tablet-trust-stats">
            <div class="tablet-stat">
              <span class="tablet-stat-number">30%</span>
              <span class="tablet-stat-label">de réservations en plus</span>
            </div>
            <div class="tablet-stat">
              <span class="tablet-stat-number">40+</span>
              <span class="tablet-stat-label">heures gagnées/sem.</span>
            </div>
            <div class="tablet-stat">
              <span class="tablet-stat-number">24/7</span>
              <span class="tablet-stat-label">de disponibilité</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Hero Intro Animation - Desktop Only -->
    <style>
      /* Desktop: Premium cinematic reveal with blur dissolve */
      @media (min-width: 1025px) {
        .hero-animate {
          opacity: 0;
          transform: translateY(30px) scale(0.98);
          filter: blur(8px);
          transition:
            opacity 1.4s cubic-bezier(0.16, 1, 0.3, 1),
            transform 1.4s cubic-bezier(0.16, 1, 0.3, 1),
            filter 1.2s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .hero-animate.visible {
          opacity: 1;
          transform: translateY(0) scale(1);
          filter: blur(0);
        }

        /* Badge - subtle float up */
        .hero-badge.hero-animate {
          transform: translateY(20px) scale(0.95);
        }
        .hero-badge.hero-animate.visible {
          transform: translateY(0) scale(1);
        }

        /* Headline - dramatic reveal */
        .hero-content h1.hero-animate {
          transform: translateY(40px) scale(0.97);
          filter: blur(12px);
        }
        .hero-content h1.hero-animate.visible {
          transform: translateY(0) scale(1);
          filter: blur(0);
        }

        /* Buttons - pop effect */
        .hero-cta-group.hero-animate {
          transform: translateY(25px) scale(0.92);
          filter: blur(6px);
        }
        .hero-cta-group.hero-animate.visible {
          transform: translateY(0) scale(1);
          filter: blur(0);
        }

        /* Spline visual - cinematic slide + scale */
        .hero-visual.hero-animate {
          opacity: 0;
          transform: translateX(80px) scale(0.9);
          filter: blur(15px);
          transition:
            opacity 1.8s cubic-bezier(0.16, 1, 0.3, 1),
            transform 1.8s cubic-bezier(0.16, 1, 0.3, 1),
            filter 1.5s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .hero-visual.hero-animate.visible {
          opacity: 1;
          transform: translateX(0) scale(1);
          filter: blur(0);
        }
      }

      /* Mobile: Always visible */
      @media (max-width: 1024px) {
        .hero-animate {
          opacity: 1 !important;
          transform: none !important;
          filter: none !important;
        }
      }
    </style>
    <script is:inline>
      (function() {
        function initHeroAnimation() {
          if (window.innerWidth < 1025) return;

          var elements = document.querySelectorAll('.hero-animate');
          if (!elements.length) return;

          // Premium staggered reveal
          elements.forEach(function(el, index) {
            var delay = parseInt(el.dataset.delay || index, 10) * 180;
            setTimeout(function() {
              el.classList.add('visible');
            }, delay + 200);
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initHeroAnimation);
        } else {
          initHeroAnimation();
        }
      })();
    </script>
  </section>

  <!-- Promo Video Section - GitHub Style -->
