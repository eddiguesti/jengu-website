            <div class="connector-line"></div>
            <div class="flow-particles">
              <div class="particle"></div>
              <div class="particle"></div>
              <div class="particle"></div>
            </div>
          </div>

          <div class="process-step">
            <div class="step-icon">
              <i class="fas fa-project-diagram"></i>
            </div>
            <div class="step-content">
