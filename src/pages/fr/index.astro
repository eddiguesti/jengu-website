              <div class="task-node chaos">
                <i class="fas fa-envelope"></i>
                <span>Emails Manuels</span>
              </div>
              <div class="task-node chaos">
                <i class="fas fa-file-alt"></i>
                <span>Tableurs</span>
              </div>
              <div class="task-node chaos">
                <i class="fas fa-phone"></i>
                <span>Appels Téléph.</span>
              </div>
              <div class="task-node chaos">
                <i class="fas fa-clipboard"></i>
                <span>Vérif. Manuelles</span>
              </div>
