  <script is:inline>
    // Homepage FAQ Toggle Function
    function toggleHomeFAQ(button) {
      const faqItem = button.parentElement;
      const answer = faqItem.querySelector('.faq-answer-home');
      const icon = button.querySelector('i');
      const isActive = faqItem.classList.contains('active');

      // Close all other FAQs
      document.querySelectorAll('.faq-item').forEach(item => {
        if (item !== faqItem && item.classList.contains('active')) {
          item.classList.remove('active');
          const otherAnswer = item.querySelector('.faq-answer-home');
          const otherIcon = item.querySelector('i');
          if (otherAnswer) otherAnswer.style.maxHeight = '0';
          if (otherIcon) otherIcon.style.transform = 'rotate(0deg)';
        }
      });

      // Toggle current FAQ
      if (isActive) {
        // Close this FAQ
        faqItem.classList.remove('active');
        answer.style.maxHeight = '0';
        icon.style.transform = 'rotate(0deg)';
      } else {
        // Open this FAQ - answer pops out underneath
        faqItem.classList.add('active');
        answer.style.maxHeight = answer.scrollHeight + 'px';
        icon.style.transform = 'rotate(180deg)';
      }
    }

    // Scroll-triggered reveal for process steps (one-way — stays visible once revealed)
    document.addEventListener('DOMContentLoaded', () => {
      const processSteps = document.querySelectorAll('.process-flow .process-step');

      // Hide elements below the viewport so they can animate in on scroll
      processSteps.forEach(step => {
        const rect = step.getBoundingClientRect();
        if (rect.top >= window.innerHeight) {
          step.classList.add('animate-hidden');
        }
      });

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.remove('animate-hidden');
            entry.target.classList.add('reveal');

            const nextConnector = entry.target.nextElementSibling;
            if (nextConnector && nextConnector.classList.contains('flow-connector')) {
              setTimeout(() => nextConnector.classList.add('draw'), 400);
            }

            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.2, rootMargin: '0px 0px -10% 0px' });

      processSteps.forEach(step => observer.observe(step));

      // Animate-on-scroll observer for stat cards, feature cards, etc.
      const animateElements = document.querySelectorAll('.animate-on-scroll');

      animateElements.forEach(el => {
        const rect = el.getBoundingClientRect();
        if (rect.top >= window.innerHeight) {
          el.classList.add('animate-hidden');
        }
      });

      const animateObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.remove('animate-hidden');
            entry.target.classList.add('visible');
          }
        });
      }, {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
      });

      animateElements.forEach(el => animateObserver.observe(el));

      // Lazy load promo video - only loads when section is visible
      // This prevents ~500KB+ background download on page load
      const promoVideo = document.getElementById('promoVideo');
      if (promoVideo && promoVideo.dataset.src) {
        let videoLoaded = false;
        const videoObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting && !videoLoaded) {
              videoLoaded = true;
              const source = document.createElement('source');
              source.src = promoVideo.dataset.src;
              source.type = 'video/mp4';
              promoVideo.appendChild(source);
              promoVideo.load();
              promoVideo.play().catch(() => {});
              videoObserver.disconnect();
            }
          });
        }, { threshold: 0.1, rootMargin: '100px' });
        videoObserver.observe(promoVideo.closest('.promo-video-section') || promoVideo);
      }
    });
  </script>
</BaseLayout>
