---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import SectionHeader from '../../components/sections/SectionHeader.astro';
import { generateSEO } from '../../lib/seo/metadata';
import { generateOrganizationSchema, generateBreadcrumbSchema } from '../../lib/seo/jsonld';

const seo = generateSEO({
  title: 'À propos de Jengu | L\'équipe derrière votre avantage IA',
  description: "Une jeune entreprise avec une longue histoire. Notre équipe d'experts en IA et en automatisation conçoit des solutions IA pragmatiques et orientées résultats pour le secteur du tourisme et de l'hôtellerie.",
  canonical: `${Astro.site}fr/about/`,
  ogType: 'article'
});

const jsonLd = [
  generateOrganizationSchema(),
  generateBreadcrumbSchema([
    { name: 'Accueil', url: Astro.site?.href || '' },
    { name: 'À propos', url: `${Astro.site}fr/about/` }
  ])
];

const teamMembers = [
  {
    name: 'Danny Smith',
    role: 'Directeur, COO à temps partagé',
    bio: 'Expert dans la conception d\'organisations distantes très performantes, Danny travaille à la croisée du design de systèmes, du comportement humain et de l\'excellence opérationnelle. Il a joué un rôle clé dans la croissance d\'Oyster, qui est passée de 14 à 500 personnes et a atteint une valorisation de 1 milliard de dollars. Son parcours d\'ingénieur logiciel et de COO l\'a mené dans plusieurs entreprises tech.',
    linkedin: 'https://www.linkedin.com/in/dannyasmith/',
    photo: '/images/team/danny-smith.webp'
  }
];
---

<BaseLayout seo={seo} jsonLd={jsonLd}>
  <!-- New Hero -->
  <header class="about-hero">
    <div class="about-hero-content">
      <h1 class="animate-on-scroll">
        Nous sommes une nouvelle entreprise avec une <span class="gradient-text">longue histoire.</span>
      </h1>
      <p class="animate-on-scroll" style="transition-delay: 0.1s;">
        Jengu a été fondée en 2023, mais notre histoire a commencé bien avant. Nous sommes un collectif d'ingénieurs IA expérimentés, d'experts en automatisation et de professionnels du secteur, réunis par le même constat : un fossé entre ce que l'IA promet et ce dont l'industrie du tourisme a réellement besoin. Nous nous sommes rassemblés pour le combler.
      </p>
    </div>
  </header>

  <!-- Our Mission & Approach -->
  <section class="mission-approach-section">
    <div class="section-container-wide">
      <div class="mission-approach-grid">
        <!-- Mission -->
        <div class="mission-card animate-on-scroll">
          <div class="card-icon">
            <i class="fas fa-flag-checkered"></i>
          </div>
          <h3>Notre mission</h3>
          <p>
            Concevoir des solutions IA pragmatiques et orientées résultats qui donnent aux entreprises du tourisme et de l'hôtellerie un véritable avantage concurrentiel. Nous traduisons une technologie complexe en résultats tangibles : temps gagné, revenus en hausse, clients plus satisfaits.
          </p>
        </div>
        <!-- Approach -->
        <div class="approach-card animate-on-scroll" style="transition-delay: 0.2s;">
          <div class="card-icon">
            <i class="fas fa-cogs"></i>
          </div>
          <h3>Notre approche</h3>
          <ol class="approach-steps">
            <li><span>1.</span> Découvrir et analyser</li>
            <li><span>2.</span> Cartographier et planifier</li>
            <li><span>3.</span> Construire et intégrer</li>
            <li><span>4.</span> Optimiser et accompagner</li>
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- Meet the Founders -->
  <section class="team-section-about">
    <div class="section-container">
      <SectionHeader
        badge="Notre équipe"
        title="Rencontrez les fondateurs"
        description="Jengu est dirigée par une équipe pragmatique : des bâtisseurs qui résolvent les vrais problèmes. Nous allions une expertise technique pointue à la passion de créer des solutions élégantes et efficaces."
      />
      <div class="team-grid-about">
        {teamMembers.map((member, index) => (
          <div class="team-member-about animate-on-scroll" style={`transition-delay: ${index * 0.1}s;`}>
            <div class="team-member-header">
              {member.photo ? (
                <img src={member.photo} alt={member.name} class="team-photo-about" />
              ) : (
                <div class="team-avatar-about">{member.initials}</div>
              )}
              <div class="team-member-info">
                <h4 class="team-name-about">{member.name}</h4>
                <p class="team-role-about">{member.role}</p>
              </div>
            </div>
            <p class="team-bio-about">{member.bio}</p>
            <a href={member.linkedin} class="linkedin-link" target="_blank" rel="noopener noreferrer">
              Voir sur LinkedIn <i class="fab fa-linkedin-in"></i>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Our Values -->
  <section class="values-section">
    <div class="section-container">
      <SectionHeader
        badge="Nos principes directeurs"
        title="Notre façon de travailler"
        description="Nos valeurs ne sont pas de simples mots affichés quelque part : ce sont les principes qui guident nos décisions, notre code et nos partenariats."
      />
      <div class="values-grid-about">
        <div class="value-card-about animate-on-scroll">
          <div class="value-icon"><i class="fas fa-handshake"></i></div>
          <h4>Partenariat pragmatique</h4>
          <p>Nous travaillons avec vous, pas pour vous. Nous sommes des partenaires technologiques concentrés sur la résolution de vos vrais problèmes avec une IA concrète et efficace — pas pour vous vendre la dernière mode du moment.</p>
        </div>
        <div class="value-card-about animate-on-scroll" style="transition-delay: 0.1s;">
          <div class="value-icon"><i class="fas fa-code"></i></div>
          <h4>Ingénierie honnête</h4>
          <p>Nous bâtissons des systèmes robustes et soignés. Notre approche repose sur la transparence, du code à la communication. Nous vous disons ce que vous devez entendre, pas seulement ce que vous voulez entendre.</p>
        </div>
        <div class="value-card-about animate-on-scroll" style="transition-delay: 0.2s;">
          <div class="value-icon"><i class="fas fa-chart-line"></i></div>
          <h4>Impact mesurable</h4>
          <p>Notre objectif : un retour sur investissement clair. Nous mesurons notre succès au vôtre — les heures que vous gagnez, les revenus que vous générez et les casse-têtes opérationnels que nous éliminons.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="about-cta-section">
    <div class="section-container">
      <div class="cta-card animate-on-scroll">
        <h2>Prêt à bâtir votre avantage ?</h2>
        <p>Parlons de la façon dont notre expérience peut vous donner une longueur d'avance sur le marché. Réservez une consultation gratuite et sans engagement avec l'un de nos fondateurs.</p>
        <button onclick="openBookingModal()" class="btn btn-primary btn-large btn-modern">
          <span>Réserver une consultation gratuite</span>
        </button>
      </div>
    </div>
  </section>

  <style>
    :root {
      --about-bg-light: #181818;
      --about-bg-dark: #0A0A0A;
      --about-border: rgba(255, 255, 255, 0.1);
    }

    /* Hero */
    .about-hero {
      padding: 10rem 2rem 8rem;
      text-align: center;
      background: var(--about-bg-dark);
      border-bottom: 1px solid var(--about-border);
    }
    .about-hero-content {
      max-width: 800px;
      margin: 0 auto;
    }
    .about-hero h1 {
      font-size: 3.5rem;
      font-weight: 700;
      margin-bottom: 1.5rem;
    }
    .about-hero p {
      font-size: 1.25rem;
      line-height: 1.7;
      color: var(--text-secondary);
    }

    /* Mission & Approach */
    .mission-approach-section {
      background: var(--about-bg-light);
      padding: 6rem 2rem;
      border-bottom: 1px solid var(--about-border);
    }
    .section-container-wide {
      max-width: 1400px;
      margin: 0 auto;
    }
    .mission-approach-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
      gap: 2rem;
    }
    .mission-card, .approach-card {
      background: var(--about-bg-dark);
      padding: 2.5rem;
      border-radius: 16px;
      border: 1px solid var(--about-border);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .mission-card:hover, .approach-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }
    .card-icon {
      font-size: 1.5rem;
      color: var(--primary-cta);
      margin-bottom: 1rem;
      width: 50px;
      height: 50px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(99, 102, 241, 0.1);
      border-radius: 12px;
    }
    .mission-card h3, .approach-card h3 {
      font-size: 1.75rem;
      margin-bottom: 1rem;
      color: var(--text-primary);
    }
    .mission-card p {
      color: var(--text-secondary);
      line-height: 1.8;
    }
    .approach-steps {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .approach-steps li {
      font-size: 1.1rem;
      color: var(--text-secondary);
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .approach-steps li span {
      font-weight: 700;
      color: var(--primary-cta);
    }

    /* Team Section */
    .team-section-about {
      padding: 6rem 2rem;
      background: var(--about-bg-dark);
      border-bottom: 1px solid var(--about-border);
    }
    .team-grid-about {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
      gap: 2rem;
      margin-top: 3rem;
    }
    .team-member-about {
      background: var(--about-bg-light);
      padding: 2rem;
      border-radius: 16px;
      border: 1px solid var(--about-border);
      display: flex;
      flex-direction: column;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .team-member-about:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }
    .team-member-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1rem;
    }
    .team-avatar-about {
      width: 50px;
      height: 50px;
      border-radius: 50%;
      background: var(--primary-cta);
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 1.25rem;
      flex-shrink: 0;
    }
    .team-photo-about {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      object-fit: cover;
      flex-shrink: 0;
      border: 2px solid var(--primary-cta);
    }
    .team-name-about {
      font-size: 1.25rem;
      color: var(--text-primary);
      margin: 0;
    }
    .team-role-about {
      color: var(--text-secondary);
      margin: 0;
      font-size: 0.9rem;
    }
    .team-bio-about {
      color: var(--text-secondary);
      line-height: 1.7;
      flex-grow: 1;
      margin-bottom: 1.5rem;
    }
    .linkedin-link {
      color: var(--primary-cta);
      text-decoration: none;
      font-weight: 600;
      transition: color 0.3s ease;
    }
    .linkedin-link:hover {
      color: #818cf8;
    }
    .team-cta {
      text-align: center;
      margin-top: 4rem;
    }

    /* Values Section */
    .values-section {
      padding: 6rem 2rem;
      background: var(--about-bg-light);
      border-bottom: 1px solid var(--about-border);
    }
    .values-grid-about {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
      gap: 2rem;
      margin-top: 3rem;
    }
    .value-card-about {
      background: var(--about-bg-dark);
      padding: 2.5rem;
      border-radius: 16px;
      text-align: center;
      border: 1px solid var(--about-border);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .value-card-about:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }
    .value-icon {
      font-size: 2rem;
      color: var(--primary-cta);
      margin-bottom: 1.5rem;
    }
    .value-card-about h4 {
      font-size: 1.5rem;
      color: var(--text-primary);
      margin-bottom: 1rem;
    }
    .value-card-about p {
      color: var(--text-secondary);
      line-height: 1.8;
    }

    /* CTA Section */
    .about-cta-section {
      padding: 6rem 2rem;
      background: var(--about-bg-dark);
    }
    .cta-card {
      max-width: 800px;
      margin: 0 auto;
      text-align: center;
      background: var(--about-bg-light);
      padding: 4rem;
      border-radius: 20px;
      border: 1px solid var(--about-border);
    }
    .cta-card h2 {
      font-size: 2.5rem;
      color: var(--text-primary);
      margin-bottom: 1.5rem;
    }
    .cta-card p {
      font-size: 1.1rem;
      color: var(--text-secondary);
      margin-bottom: 2rem;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .about-hero { padding: 8rem 1.5rem 6rem; }
      .about-hero h1 { font-size: 2.75rem; }
      .about-hero p { font-size: 1.1rem; }

      .mission-approach-section,
      .team-section-about,
      .values-section,
      .about-cta-section {
        padding: 4rem 1.5rem;
      }
      .mission-approach-grid { grid-template-columns: 1fr; }
      .team-grid-about { grid-template-columns: 1fr; }
      .values-grid-about { grid-template-columns: 1fr; }

      .cta-card { padding: 2.5rem; }
      .cta-card h2 { font-size: 2rem; }
    }

  </style>
</BaseLayout>
