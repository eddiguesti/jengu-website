---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import SectionHeader from '../../components/sections/SectionHeader.astro';
import CTASection from '../../components/sections/CTASection.astro';
import { generateSEO } from '../../lib/seo/metadata';
import { generateOrganizationSchema, generateBreadcrumbSchema } from '../../lib/seo/jsonld';

const seo = generateSEO({
  title: 'Services d\'automatisation IA pour les entreprises touristiques',
  description: 'Chatbots IA, bots vocaux, logiciels sur mesure et intégrations API pour le tourisme. Support client 24h/24 et 7j/7, gestion intelligente des e-mails, tarification dynamique et intégration fluide à votre PMS. Transformez vos opérations.',
  canonical: `${Astro.site}fr/services/`,
  ogType: 'website'
});

const jsonLd = [
  generateOrganizationSchema(),
  generateBreadcrumbSchema([
    { name: 'Accueil', url: Astro.site?.href || '' },
    { name: 'Services', url: `${Astro.site}fr/services/` }
  ])
];
---

<BaseLayout seo={seo} jsonLd={jsonLd}>
  <Hero
    title="Nos"
    highlight="Services"
    description="Des chatbots IA et bots vocaux aux logiciels sur mesure et intégrations API — nous concevons des solutions intelligentes qui transforment les opérations touristiques"
  />

  <!-- Main Services -->
  <section class="services-section">
    <div class="section-container">
      <SectionHeader
        badge="Ce que nous construisons"
        title="Solutions d'IA et d'automatisation sur mesure"
        description="Une technologie taillée pour vos enjeux opérationnels"
      />

      <div class="services-grid">
        <!-- AI Chatbots & Phone Bots -->
        <div class="service-card">
          <div class="service-icon">
            <i class="fas fa-robot"></i>
          </div>
          <h3>Chatbots IA et bots vocaux</h3>
          <p>Des agents IA conversationnels sur mesure qui gèrent les communications clients 24h/24, 7j/7 par texte et par voix.</p>
          <ul class="service-features">
            <li>Traitement du langage naturel dans plus de 100 langues</li>
            <li>IA vocale pour des appels téléphoniques aux conversations naturelles</li>
            <li>Intégration au chat web, à WhatsApp et aux SMS</li>
            <li>Automatisation des réservations, des demandes et du support</li>
            <li>Passage de relais fluide vers un agent humain quand c'est nécessaire</li>
          </ul>
          <a href="/fr/contact" class="service-cta">En savoir plus →</a>
        </div>

        <!-- Custom Software Development -->
        <div class="service-card">
          <div class="service-icon">
            <i class="fas fa-code"></i>
          </div>
          <h3>Développement logiciel sur mesure</h3>
          <p>Des applications conçues spécifiquement pour vos flux de travail et vos besoins opérationnels.</p>
          <ul class="service-features">
            <li>Moteurs de tarification dynamique optimisés par IA</li>
            <li>Systèmes de réservation sur mesure</li>
            <li>Outils de gestion des stocks et des ressources</li>
            <li>Tableaux de bord analytiques et plateformes de reporting</li>
            <li>Applications mobiles pour le personnel et les clients</li>
          </ul>
          <a href="/fr/contact" class="service-cta">En savoir plus →</a>
        </div>

        <!-- API Integrations -->
        <div class="service-card">
          <div class="service-icon">
            <i class="fas fa-network-wired"></i>
          </div>
          <h3>Intégrations API et automatisation</h3>
          <p>Connectez toute votre stack technique avec des flux de travail intelligents qui éliminent la saisie manuelle et les erreurs.</p>
          <ul class="service-features">
            <li>Intégrations PMS, CRM et moteurs de réservation</li>
            <li>Synchronisation avec vos prestataires de paiement et logiciels comptables</li>
            <li>Connexions aux channel managers et aux OTA</li>
            <li>Automatisation des plateformes de messagerie et de communication</li>
            <li>Middleware sur mesure pour vos systèmes existants</li>
          </ul>
          <a href="/fr/contact" class="service-cta">En savoir plus →</a>
        </div>

        <!-- Email Automation -->
        <div class="service-card">
          <div class="service-icon">
            <i class="fas fa-envelope"></i>
          </div>
          <h3>Gestion intelligente des e-mails</h3>
          <p>Tri, catégorisation et réponses automatiques intelligents pour gérer vos communications clients à grande échelle.</p>
          <ul class="service-features">
            <li>Organisation et priorisation intelligentes des messages</li>
            <li>Réponses générées par IA dans le ton de votre marque</li>
            <li>Catégorisation et routage automatiques</li>
            <li>Analyse de sentiment pour repérer les urgences</li>
            <li>Intégration aux outils de ticketing</li>
          </ul>
          <a href="/fr/contact" class="service-cta">En savoir plus →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Additional Services -->
  <section class="services-section" style="padding-top: 0;">
    <div class="section-container">
      <div class="services-grid">
        <!-- Process Mapping -->
        <div class="service-card">
          <div class="service-icon">
            <i class="fas fa-project-diagram"></i>
          </div>
          <h3>Cartographie et optimisation des processus</h3>
          <p>Une vision claire de vos flux de travail pour identifier les freins et les opportunités d'automatisation.</p>
          <ul class="service-features">
            <li>Documentation complète des flux de travail</li>
            <li>Identification et analyse des goulots d'étranglement</li>
            <li>Évaluation des opportunités d'automatisation</li>
            <li>Calcul du ROI pour chaque amélioration</li>
            <li>Élaboration d'une feuille de route de mise en œuvre</li>
          </ul>
          <a href="/fr/contact" class="service-cta">En savoir plus →</a>
        </div>

        <!-- Training & Support -->
        <div class="service-card">
          <div class="service-icon">
            <i class="fas fa-graduation-cap"></i>
          </div>
          <h3>Formation et support continu</h3>
          <p>Une intégration complète et un accompagnement dans la durée pour que votre équipe maîtrise pleinement chaque système que nous construisons.</p>
          <ul class="service-features">
            <li>Formation pratique pour tous les niveaux d'utilisateurs</li>
            <li>Documentation sur mesure et tutoriels vidéo</li>
            <li>Équipe de support dédiée pendant les heures de bureau</li>
            <li>Audits réguliers d'optimisation des systèmes</li>
            <li>Mises à jour des fonctionnalités et améliorations</li>
          </ul>
          <a href="/fr/contact" class="service-cta">En savoir plus →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="process-section">
    <div class="section-container">
      <SectionHeader
        badge="Notre méthode"
        title="Notre processus de développement"
        description="De la découverte au déploiement, nous suivons un processus éprouvé qui produit des résultats concrets"
      />

      <div class="process-steps">
        <div class="process-step">
          <div class="process-number">1</div>
          <h4>Découverte</h4>
          <p>Nous cartographions vos processus, comprenons vos défis et identifions les opportunités d'automatisation</p>
        </div>
        <div class="process-step">
          <div class="process-number">2</div>
          <h4>Conception</h4>
          <p>Une solution sur mesure, conçue autour de vos flux de travail et de vos objectifs commerciaux</p>
        </div>
        <div class="process-step">
          <div class="process-number">3</div>
          <h4>Développement</h4>
          <p>Développement agile, avec des points réguliers et des cycles de retours itératifs</p>
        </div>
        <div class="process-step">
          <div class="process-number">4</div>
          <h4>Déploiement et support</h4>
          <p>Lancement progressif, formation des équipes, optimisation et accompagnement continus</p>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="Prêt à automatiser vos opérations ?"
    description="Calculez votre ROI potentiel en 2 minutes"
  />
</BaseLayout>
