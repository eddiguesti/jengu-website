---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const siteUrl = 'https://www.jengu.ai';

// Pages that have French and Spanish translations
// Only these paths will get hreflang links
const multilingualPaths = new Set([
  '/',
  '/about',
  '/blog',
  '/book',
  '/calculator',
  '/case-studies',
  '/contact',
  '/dynamic-pricing',
  '/faq',
  '/privacy',
  '/services',
  '/team',
  '/terms'
]);

// Extract the path without locale prefix
let basePath = currentPath;
if (currentPath.startsWith('/fr/')) {
  basePath = currentPath.substring(3);
} else if (currentPath.startsWith('/es/')) {
  basePath = currentPath.substring(3);
} else if (currentPath === '/fr' || currentPath === '/es') {
  basePath = '/';
}

// Ensure basePath starts with /
if (!basePath.startsWith('/')) {
  basePath = '/' + basePath;
}

// Normalise trailing slash (Astro builds with format: 'directory' → all URLs end in /)
const matchPath = basePath !== '/' && basePath.endsWith('/') ? basePath.slice(0, -1) : basePath;
const urlPath = basePath === '/' ? '/' : (basePath.endsWith('/') ? basePath : `${basePath}/`);

// Check if this path has multilingual support (compared without trailing slash)
const hasTranslations = multilingualPaths.has(matchPath);

const enUrl = `${siteUrl}${urlPath}`;
const frUrl = urlPath === '/' ? `${siteUrl}/fr/` : `${siteUrl}/fr${urlPath}`;
const esUrl = urlPath === '/' ? `${siteUrl}/es/` : `${siteUrl}/es${urlPath}`;
---

{/* Only render hreflang links if translations exist for this path. */}
{/* Canonical is handled by SEOHead.astro on every page. */}
{hasTranslations && (
  <>
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="fr" href={frUrl} />
    <link rel="alternate" hreflang="es" href={esUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />
  </>
)}
