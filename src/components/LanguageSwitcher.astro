---
import { getLocaleFromUrl } from '../i18n';

const currentPath = Astro.url.pathname;
const currentLocale = getLocaleFromUrl(currentPath);

let basePath = currentPath;
if (currentPath.startsWith('/fr/')) {
  basePath = currentPath.substring(3);
} else if (currentPath.startsWith('/es/')) {
  basePath = currentPath.substring(3);
}

if (!basePath.startsWith('/')) {
  basePath = '/' + basePath;
}

if (basePath !== '/' && basePath.endsWith('/')) {
  basePath = basePath.slice(0, -1);
}

const enPath = basePath;
const frPath = '/fr' + basePath;
const esPath = '/es' + basePath;

const languages = [
  { code: 'en', label: 'EN', href: enPath, aria: 'English' },
  { code: 'fr', label: 'FR', href: frPath, aria: 'Français' },
  { code: 'es', label: 'ES', href: esPath, aria: 'Español' },
];

const activeIndex = Math.max(0, languages.findIndex(l => l.code === currentLocale));
---

<div class="language-switcher" role="group" aria-label="Language" data-active-index={activeIndex}>
  <span class="lang-indicator" aria-hidden="true"></span>
  {languages.map(({ code, label, href, aria }) => (
    <a
      href={href}
      data-lang-switch={code}
      class={currentLocale === code ? 'lang-pill active' : 'lang-pill'}
      aria-label={aria}
      aria-current={currentLocale === code ? 'true' : undefined}
    >
      <span class="lang-pill-text">{label}</span>
    </a>
  ))}
</div>

<style>
  .language-switcher {
    position: relative;
    display: inline-flex;
    padding: 3px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
    isolation: isolate;
    transition: border-color 0.3s ease, background 0.3s ease;
  }

  .language-switcher:hover {
    border-color: rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.06);
  }

  .lang-indicator {
    position: absolute;
    top: 3px;
    bottom: 3px;
    left: 3px;
    width: calc((100% - 6px) / 3);
    border-radius: 999px;
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 60%, #a855f7 100%);
    box-shadow:
      0 2px 10px rgba(99, 102, 241, 0.45),
      0 0 0 1px rgba(255, 255, 255, 0.08) inset,
      0 1px 0 rgba(255, 255, 255, 0.22) inset;
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 0;
    pointer-events: none;
  }

  .language-switcher[data-active-index="0"] .lang-indicator { transform: translateX(0); }
  .language-switcher[data-active-index="1"] .lang-indicator { transform: translateX(100%); }
  .language-switcher[data-active-index="2"] .lang-indicator { transform: translateX(200%); }

  .lang-pill {
    position: relative;
    z-index: 1;
    flex: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    padding: 0.34rem 0.62rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    border-radius: 999px;
    transition: color 0.25s ease;
    -webkit-tap-highlight-color: transparent;
  }

  .lang-pill-text {
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }

  .lang-pill:hover {
    color: rgba(255, 255, 255, 0.95);
  }

  .lang-pill:hover .lang-pill-text {
    transform: translateY(-1px);
  }

  .lang-pill.active {
    color: #fff;
    text-shadow: 0 1px 2px rgba(31, 0, 92, 0.35);
  }

  .lang-pill.active:hover .lang-pill-text {
    transform: none;
  }

  .lang-pill:focus-visible {
    outline: 2px solid rgba(168, 85, 247, 0.65);
    outline-offset: 3px;
  }

  @media (max-width: 767px) {
    .language-switcher {
      padding: 2px;
    }

    .lang-pill {
      min-width: 30px;
      padding: 0.28rem 0.5rem;
      font-size: 0.68rem;
      letter-spacing: 0.06em;
    }
  }

  @media (max-width: 479px) {
    .lang-pill {
      min-width: 28px;
      padding: 0.26rem 0.42rem;
      font-size: 0.66rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lang-indicator,
    .lang-pill,
    .lang-pill-text,
    .language-switcher {
      transition: none;
    }
  }
</style>
